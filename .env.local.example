# n8n Webhook Configuration
# Replace this with your actual n8n webhook URL from your "Working RSS newsfeed v1" workflow
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-id

# Example: If your n8n is running locally
# N8N_WEBHOOK_URL=http://localhost:5678/webhook/sunidhi-rss-feed

# Example: If your n8n is on n8n.cloud
# N8N_WEBHOOK_URL=https://yourname.app.n8n.cloud/webhook/sunidhi-rss-feed
