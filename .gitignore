# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env*.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# data files (sensitive user data)
/data/*.json
!/data/.gitkeep

# uploaded files
/public/uploads/*
!/public/uploads/.gitkeep

# logs
logs
*.log

# IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea
*.swp
*.swo
*~

# OS
Thumbs.db
.DS_Store

# Security — credentials, secrets
/_secure_backup/
*.txt
!robots.txt
*CREDENTIALS*
*credentials*

# Proprietary research PDFs (served through authenticated API — not source code)
/public/research-reports/
/public/research-files/
/public/daily-updates/
/public/research-data/

# Blog images (uploaded at runtime, not source code)
/public/images/blog/

# Legal/compliance document binaries (not source code)
/public/legal-documents/
/public/SSFL-CSR-Policy.pdf

# Root-level binary reference files (not part of the application)
*.pdf
*.pptx
*.docx
*.xlsx
/Images/

# IIS/iisnode server runtime logs
/iisnode/

# User submission data and PII exports (never commit)
/feedback-submissions/
clientIds.csv
*.csv
# Init scripts with real credentials — use init-users.js (demo data) as template instead
scripts/init-admins.js
scripts/init-super-admin.js
scripts/migrate-clients.js
sunidhi-export-for-seo/scripts/init-admins.js
sunidhi-export-for-seo/scripts/init-super-admin.js

# Claude Code internal files
/.claude/

# Windows IIS-specific deployment helpers (internal network info)
*.bat
*.ps1
web.config
IIS-web.config
